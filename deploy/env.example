FMC_ENV=production
FMC_PUBLIC_ORIGIN=https://agentzero.kitabu.ai
FMC_AUTH_MODE=local
FMC_ADMIN_EMAIL=you@example.com
FMC_PROVIDER=nvidia
FMC_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
FMC_NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
FMC_RELEASE_SHA=FULL_GIT_SHA
FMC_IMAGE=ghcr.io/samorakibagendi254/find-my-customer@sha256:IMAGE_DIGEST
FMC_RUN_LIMIT_ACTIVE=2
FMC_RUN_LIMIT_DAILY=10
LOG_LEVEL=INFO
