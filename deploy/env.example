FMC_ENV=production
FMC_PUBLIC_ORIGIN=https://agentzero.kitabu.ai
FMC_AUTH_MODE=cloudflare
FMC_CF_TEAM_DOMAIN=https://YOUR_TEAM.cloudflareaccess.com
FMC_ALLOWED_EMAILS=you@example.com
FMC_PROVIDER=openai
FMC_OPENAI_MODEL=gpt-5.2
FMC_RELEASE_SHA=FULL_GIT_SHA
FMC_IMAGE=ghcr.io/samorakibagendi254/find-my-customer@sha256:IMAGE_DIGEST
FMC_RUN_LIMIT_ACTIVE=2
FMC_RUN_LIMIT_DAILY=10
LOG_LEVEL=INFO
